<project>
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>io.github.linguaphylo</groupId>
        <artifactId>lphybeast-root</artifactId>
        <version>2.0.0-SNAPSHOT</version>
    </parent>
    <name>lphybeast</name>
    <artifactId>lphybeast</artifactId>

    <dependencies>
        <!-- BEAST 3 -->
        <dependency>
            <groupId>io.github.compevol</groupId>
            <artifactId>beast-base</artifactId>
        </dependency>
        <dependency>
            <groupId>io.github.compevol</groupId>
            <artifactId>beast-pkgmgmt</artifactId>
        </dependency>

        <!-- LPhy -->
        <dependency>
            <groupId>io.github.linguaphylo</groupId>
            <artifactId>lphy-base</artifactId>
        </dependency>

        <!-- Utilities -->
        <dependency>
            <groupId>com.google.guava</groupId>
            <artifactId>guava</artifactId>
            <version>33.2.1-jre</version>
        </dependency>

        <!-- BEASTLabs -->
        <dependency>
            <groupId>io.github.beast2-dev</groupId>
            <artifactId>beast-labs</artifactId>
            <version>2.1.0-beta2</version>
        </dependency>

        <!-- BEAST Classic -->
        <dependency>
            <groupId>io.github.beast2-dev</groupId>
            <artifactId>beast-classic</artifactId>
            <version>1.7.0-beta1</version>
            <exclusions>
                <!-- netlib natives JARs have filenames that contain 'native',
                     a Java keyword, making them invalid as JPMS automatic
                     modules. Exclude from module path; mtj loads them via
                     the system class loader at runtime. -->
                <exclusion>
                    <groupId>com.github.fommil.netlib</groupId>
                    <artifactId>*</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>com.github.fommil</groupId>
                    <artifactId>*</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- BEAGLE (optional in beast-base, needed at runtime for TreeLikelihood) -->
        <dependency>
            <groupId>io.github.beagle-dev</groupId>
            <artifactId>beagle</artifactId>
            <version>1.0.0</version>
        </dependency>

        <!-- Optional dependencies moved to extension modules:
             substmodels         -> lphybeast-ssm
             feast              -> lphybeast-feast
             beast-bdtree       -> lphybeast-bdtree
             beast-coupled-mcmc -> lphybeast-mc3
             beast-mutable-alignment -> lphybeast-ma
        -->

        <!-- Testing -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.15.0</version>
                <configuration>
                    <release>25</release>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.4.2</version>
                <configuration>
                    <archive>
                        <manifest>
                            <addDefaultImplementationEntries>true</addDefaultImplementationEntries>
                            <addDefaultSpecificationEntries>true</addDefaultSpecificationEntries>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>exec-maven-plugin</artifactId>
                <version>3.6.3</version>
                <configuration>
                    <executable>java</executable>
                    <classpathScope>compile</classpathScope>
                    <!-- Put all deps on the module path and resolve lphy.beast
                         as a named module so its `provides LPhyBEASTMapping`
                         declaration is visible to ServiceLoader. -->
                    <commandlineArgs>-Dpicocli.disable.closures=true --module-path %classpath --add-modules lphy.beast -m lphy.beast/lphybeast.LPhyBeastMain ${lphybeast.args}</commandlineArgs>
                </configuration>
            </plugin>
            <!-- Resolve dependency artifact paths as properties for surefire -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>3.6.1</version>
                <executions>
                    <execution>
                        <goals><goal>properties</goal></goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.1.2</version>
                <configuration>
                    <systemPropertyVariables>
                        <!-- Tell BEASTClassLoader.initServices() where to find
                             beast-base's version.xml (embedded in the JAR) -->
                        <BEAST_PACKAGE_PATH>${io.github.compevol:beast-base:jar}</BEAST_PACKAGE_PATH>
                    </systemPropertyVariables>
                    <argLine>
                        --add-reads lphy.beast=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
